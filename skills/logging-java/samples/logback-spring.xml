<!-- Sample: Logback configuration for Spring Boot with JSON output and MDC -->
<!-- Place in src/main/resources/logback-spring.xml -->
<configuration scan="true" scanPeriod="30 seconds">

    <!-- Property from Spring Boot -->
    <springProperty scope="context" name="appName" source="spring.application.name"
                    defaultValue="my-app"/>

    <!-- Console Appender (dev) -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level [%X{correlationId:-N/A}] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Rolling File Appender -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/${appName}.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>logs/${appName}-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [%X{correlationId:-N/A}] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- JSON Appender (production) — requires logstash-logback-encoder -->
    <springProfile name="prod,staging">
        <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <includeMdcKeyName>correlationId</includeMdcKeyName>
                <includeMdcKeyName>userId</includeMdcKeyName>
                <customFields>{"application":"${appName}"}</customFields>
            </encoder>
        </appender>
    </springProfile>

    <!-- Filter noisy frameworks -->
    <logger name="org.springframework.security" level="WARN"/>
    <logger name="org.hibernate.SQL" level="WARN"/>
    <logger name="org.hibernate.type.descriptor.sql.BasicBinder" level="WARN"/>
    <logger name="org.apache.catalina" level="WARN"/>

    <!-- Dev profile: console + file -->
    <springProfile name="dev,default">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>
        <logger name="com.myapp" level="DEBUG"/>
    </springProfile>

    <!-- Prod/staging: JSON output -->
    <springProfile name="prod,staging">
        <root level="INFO">
            <appender-ref ref="JSON"/>
        </root>
        <logger name="com.myapp" level="INFO"/>
    </springProfile>

</configuration>
